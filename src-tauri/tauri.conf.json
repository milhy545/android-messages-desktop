{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unifik\u00e1tor",
  "version": "0.1.0",
  "identifier": "com.milhy.unifikator",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "pnpm install"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Unifik\u00e1tor",
        "width": 1100,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "Unifik\u00e1tor"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}